{
  "permissions": {
    "allow": [
      "Bash(python3 scripts/*)",
      "Bash(node scripts/*)",
      "Bash(sqlite3 data/gtm.db *)",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node hooks/context-monitor.js"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node hooks/session-start.js"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "command": "node hooks/statusline.js"
  }
}
